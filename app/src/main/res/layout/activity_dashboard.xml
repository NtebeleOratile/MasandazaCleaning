<?xml version="1.0" encoding="utf-8"?>
<!--
    Dashboard screen for Masandaza Cleaning app.
    Uses ConstraintLayout for high-performance, flat view hierarchy.
    This layout dynamically toggles sections based on whether the user is a Customer or Staff.
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FE">

    <!-- Blue header background decorative element -->
    <View
        android:id="@+id/headerBackground"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="@color/blue_primary"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Top Header Bar with Logo and Logout -->
    <LinearLayout
        android:id="@+id/llHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="20dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/logo"
            android:background="@drawable/circle_white"
            android:padding="8dp"
            android:contentDescription="App Logo" />

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Masandaza Cleaning"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="12dp" />

        <TextView
            android:id="@+id/btnLogout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Logout"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:padding="8dp"
            android:background="?android:attr/selectableItemBackground" />
    </LinearLayout>

    <!-- Welcome Message Section -->
    <TextView
        android:id="@+id/tvWelcome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Welcome!"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:layout_marginStart="20dp"
        app:layout_constraintTop_toBottomOf="@id/llHeader"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="What would you like to do today?"
        android:textColor="#E0E0E0"
        android:textSize="14sp"
        android:layout_marginStart="20dp"
        app:layout_constraintTop_toBottomOf="@id/tvWelcome"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Statistics Quick-View (Visible to Customers only) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardStats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp">

            <!-- Active Bookings Counter -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/tvActiveBookingsCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/blue_primary" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Active Bookings"
                    android:textSize="12sp"
                    android:textColor="@color/gray_text" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="1dp"
                android:layout_height="40dp"
                android:background="#EEEEEE"
                android:layout_gravity="center_vertical" />

            <!-- Pending Payments Counter -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/tvPendingPaymentsCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/red_accent" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pending Payments"
                    android:textSize="12sp"
                    android:textColor="@color/gray_text" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Scrollable content area for Dashboard Tiles -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/cardStats"
        app:layout_constraintBottom_toTopOf="@id/bottom_navigation">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- CUSTOMER SERVICES SECTION (Book service, Track, Payments) -->
            <LinearLayout
                android:id="@+id/llServicesSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Services"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/dark_text"
                    android:layout_marginBottom="16dp" />

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:alignmentMode="alignMargins"
                    android:columnOrderPreserved="false">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardBookService"
                        style="@style/DashboardTileStyle">
                        <LinearLayout style="@style/DashboardTileContentStyle">
                            <ImageView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:src="@drawable/ic_bookings"
                                app:tint="@color/blue_primary"
                                android:background="@drawable/circle_blue_light"
                                android:padding="12dp" />
                            <TextView
                                style="@style/DashboardTileTitleStyle"
                                android:text="Book Service" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardTrackOrder"
                        style="@style/DashboardTileStyle">
                        <LinearLayout style="@style/DashboardTileContentStyle">
                            <ImageView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:src="@drawable/ic_home"
                                app:tint="@color/blue_primary"
                                android:background="@drawable/circle_blue_light"
                                android:padding="12dp" />
                            <TextView
                                style="@style/DashboardTileTitleStyle"
                                android:text="Track Orders" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardPayments"
                        style="@style/DashboardTileStyle">
                        <LinearLayout style="@style/DashboardTileContentStyle">
                            <ImageView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:src="@drawable/ic_payments"
                                app:tint="@color/blue_primary"
                                android:background="@drawable/circle_blue_light"
                                android:padding="12dp" />
                            <TextView
                                style="@style/DashboardTileTitleStyle"
                                android:text="Payments" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardProfile"
                        style="@style/DashboardTileStyle">
                        <LinearLayout style="@style/DashboardTileContentStyle">
                            <ImageView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:src="@drawable/ic_profile"
                                app:tint="@color/blue_primary"
                                android:background="@drawable/circle_blue_light"
                                android:padding="12dp" />
                            <TextView
                                style="@style/DashboardTileTitleStyle"
                                android:text="Profile" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </GridLayout>
            </LinearLayout>

            <!-- STAFF MANAGEMENT SECTION (Visible to Staff only) -->
            <LinearLayout
                android:id="@+id/llStaffSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="24dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Staff Tools"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/dark_text"
                    android:layout_marginBottom="16dp" />

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:alignmentMode="alignMargins"
                    android:columnOrderPreserved="false">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardStaffDashboard"
                        style="@style/DashboardTileStyle">
                        <LinearLayout style="@style/DashboardTileContentStyle">
                            <ImageView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:src="@drawable/ic_profile"
                                app:tint="@color/red_accent"
                                android:background="@drawable/circle_red_light"
                                android:padding="12dp" />
                            <TextView
                                style="@style/DashboardTileTitleStyle"
                                android:text="Staff Panel" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardReports"
                        style="@style/DashboardTileStyle">
                        <LinearLayout style="@style/DashboardTileContentStyle">
                            <ImageView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:src="@drawable/ic_payments"
                                app:tint="@color/red_accent"
                                android:background="@drawable/circle_red_light"
                                android:padding="12dp" />
                            <TextView
                                style="@style/DashboardTileTitleStyle"
                                android:text="Reports" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardUpdateStatus"
                        style="@style/DashboardTileStyle">
                        <LinearLayout style="@style/DashboardTileContentStyle">
                            <ImageView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:src="@drawable/ic_home"
                                app:tint="@color/red_accent"
                                android:background="@drawable/circle_red_light"
                                android:padding="12dp" />
                            <TextView
                                style="@style/DashboardTileTitleStyle"
                                android:text="Update Status" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </GridLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Navigation Hub -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:menu="@menu/bottom_nav_menu"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
